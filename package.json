{
  "name": "nova-client",
  "version": "11.0.0",
  "description": "Nova Client - Minecraft Launcher",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --x64",
    "dev": "electron . --dev"
  },
  "build": {
    "appId": "com.novaclient.launcher",
    "productName": "Nova Client",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "package.json",
      "src/**/*",
      "assets/**/*",
      "fabric-mod/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "fs-extra": "^11.2.0",
    "minecraft-launcher-core": "^3.12.2",
    "msmc": "^4.0.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
